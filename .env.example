PORT=3000
NODE_ENV=
SITE_URL=https://tudominio.com

# En Render/Vercel/hosting usa el host público de tu proveedor MySQL.
# No uses 127.0.0.1 ni localhost en producción: eso apunta al servidor web, no a tu base de datos.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_CONNECTION_LIMIT=
MYSQL_TIMEZONE=

ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=change_this_password
# Genera una contraseña larga y única. Nunca subas tu archivo .env al repositorio.
SESSION_SECRET=

# Usuario dueño del proyecto. Solo este rol ve Licencia / Estado del sitio.
# IMPORTANTE: copia estos valores reales al archivo .env. Este .env.example no se carga al iniciar.
OWNER_EMAIL=owner@tudominio.com
OWNER_PASSWORD=change_this_owner_password
OWNER_NAME=Owner

WHATSAPP_PHONE=18090000000
WHATSAPP_ULTRACOMP=18090000000
WHATSAPP_ULTRASOFT=18090000000

# En producción usa una ruta montada en almacenamiento persistente.
# Render recomendado: crea un Persistent Disk montado en /var/data y usa /var/data/IMAGENES.
UPLOAD_DIR=./IMAGENES
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14

# Envío del formulario de contacto de Ultrasoft
ULTRASOFT_CONTACT_EMAIL=contacto@tudominio.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Formulario Ultrasoft <contacto@tudominio.com>
